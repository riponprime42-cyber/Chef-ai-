{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/chefai-debug.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"chefai-debug.apk\""
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/chefai-debug.apk",
      "dest": "/chefai-debug.apk"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
